# Copy this file to .env and fill in real values. Never commit .env.

# Postgres superuser password used by the postgres service and by
# POKERD_DATABASE_URL below. Change this to a strong random value.
POSTGRES_PASSWORD=change-me-fake-password

# Full Postgres connection string pokerd uses. Host "postgres" is the
# compose service name, resolved on the compose network.
POKERD_DATABASE_URL=postgres://pokerd:change-me-fake-password@postgres:5432/pokerd?sslmode=disable

# HMAC secret pokerd uses to sign auth tokens. Must be set in production,
# otherwise pokerd generates a random ephemeral secret on every restart
# and invalidates all existing sessions. Generate with: openssl rand -hex 32
POKERD_AUTH_SECRET=fake-dev-secret-do-not-use-in-prod-0000000000000000

# Comma-separated list of origins allowed to open WebSocket connections.
# When unset, only local dev origins (localhost/127.0.0.1) are allowed, so a
# remote client with this unset is rejected.
POKERD_ALLOWED_ORIGINS=https://example.com,https://www.example.com

# Marks a production deployment. When set to "production", pokerd refuses to
# start if POKERD_DATABASE_URL or POKERD_AUTH_SECRET is missing, instead of
# silently falling back to data-losing in-memory stores. The compose stack sets
# this for you; leave it unset for local dev.
POKERD_ENV=production

# Build version stamped into the pokerd image and reported by GET /healthz.
# Set to a git tag or short SHA in CI; defaults to "dev".
POKERD_VERSION=dev
